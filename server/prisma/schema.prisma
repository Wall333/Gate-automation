// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ── Users ────────────────────────────────────────────────
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String
  picture   String   @default("")
  role      String   @default("user")   // "user" | "admin"
  status    String   @default("pending") // "pending" | "approved" | "denied"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs              AuditLog[]
  gateEvents             GateEvent[]
  notificationPreference NotificationPreference?
}

// ── Devices ──────────────────────────────────────────────
model Device {
  id        String   @id @default(uuid())
  name      String
  tokenHash String
  isOnline  Boolean  @default(false)
  isOpen    Boolean  @default(false)
  lastSeen  DateTime?
  createdAt DateTime @default(now())

  auditLogs  AuditLog[]
  gateEvents GateEvent[]
}

// ── Gate Events (activity feed) ──────────────────────────
model GateEvent {
  id                String   @id @default(uuid())
  deviceId          String
  event             String   // "OPENED" | "CLOSED"
  triggeredBy       String?  // User name if app-triggered, null if manual/remote
  triggeredByUserId String?  // FK to User, null if manual/remote
  timestamp         DateTime @default(now())

  device Device @relation(fields: [deviceId], references: [id])
  user   User?  @relation(fields: [triggeredByUserId], references: [id])
}

// ── Notification Preferences ─────────────────────────────
model NotificationPreference {
  id             String   @id @default(uuid())
  userId         String   @unique
  notifyOnOpen   Boolean  @default(false)
  notifyOnClose  Boolean  @default(false)
  openTooLongMin Int?     // null = disabled
  fcmToken       String?  // Expo push token (column name kept for compat)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

// ── Audit Log ────────────────────────────────────────────
model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  deviceId  String
  action    String   // "TOGGLE"
  result    String   // "ACK" | "TIMEOUT" | "DEVICE_OFFLINE"
  timestamp DateTime @default(now())

  user   User   @relation(fields: [userId],   references: [id])
  device Device @relation(fields: [deviceId], references: [id])
}

// ── Firmware ─────────────────────────────────────────────
model Firmware {
  id          String   @id @default(uuid())
  filename    String               // Original uploaded filename
  storedName  String   @unique     // Name on disk (uuid-based)
  version     String   @default("") // Optional user-supplied version label
  size        Int                  // File size in bytes
  uploadedAt  DateTime @default(now())
}
